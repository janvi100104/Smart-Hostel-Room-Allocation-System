# ==================================
*.pem
*.log
*.pid
*.seed
*.pid.lock
lock-gyp
*.tgz
*.tar
*.tar.gz
*.rar
*.zip
*.7z

# ==================================
# Optional npm debug logs
# ==================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==================================
# Package Manager Locks (Keep one!)
# ==================================
# Keep package-lock.json OR yarn.lock OR pnpm-lock.yaml
# Uncomment the ones you don't use:

# yarn.lock
# pnpm-lock.yaml

# ==================================
# Storybook
# ==================================
storybook-static/
.storybook-cache/

# ==================================
# Playwright
# ==================================
playwright-report/
playwright/.cache/

# ==================================
# Sentry
# ==================================
.sentryclirc
sentry.properties

# ==================================
# GraphQL Code Generator
# ==================================
graphql.config.json
.graphqlrc
.graphqlrc.json
.graphqlrc.yaml
.graphqlrc.yml

# ==================================
# Husky
# ==================================
.husky/.gitignore

# ==================================
# Turbo
# ==================================
.turbo
turbo.log

# ==================================
# Comments
# ==================================
# This .gitignore is optimized for Next.js + TypeScript projects
# Feel free to customize based on your project needs
